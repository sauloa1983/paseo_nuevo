DirectoryIndex index.php

# Algunos hostings LiteSpeed bloquean POST de Livewire (login Filament)
<IfModule mod_security.c>
    SecFilterEngine Off
    SecFilterScanPOST Off
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Dominio antiguo -> sitio actual (301 permanente, conserva ruta y query)
    RewriteCond %{HTTP_HOST} ^(www\.)?paseoespanainmobiliaria\.com$ [NC]
    RewriteRule ^ https://www.paseoespana.com%{REQUEST_URI} [R=301,L]

    # paseoespana.com (sin www) -> www.paseoespana.com
    RewriteCond %{HTTP_HOST} ^paseoespana\.com$ [NC]
    RewriteRule ^ https://www.paseoespana.com%{REQUEST_URI} [R=301,L]

    # HTTP -> HTTPS en el dominio principal
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} ^www\.paseoespana\.com$ [NC]
    RewriteRule ^ https://www.paseoespana.com%{REQUEST_URI} [R=301,L]

    RewriteRule ^(livewire|entrar|acceso|cambiar-clave|filament|pe-panel|gestion|crear-storage-link|limpiar-sistema|limpiar-vistas|diag-panel|diag-storage|media)(/.*)?$ index.php [L,QSA]

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_authz_core.c>
    Require all granted
</IfModule>
